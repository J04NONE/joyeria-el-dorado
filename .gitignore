# Joyería El Dorado - .gitignore

# === Playwright MCP (auditoría/pruebas locales) ===
.playwright-mcp/

# === Python / Django ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
build/
dist/
.eggs/
**/*.egg-info/
*.db
*.sqlite3

# === Entorno Virtual ===
venv/
.env/
env_joyeria/
backend/env_joyeria/

# === Archivos multimedia (subidos por usuarios) ===
media/

# === Variables de Entorno ===
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# === Node.js (si se usa en el futuro) ===
node_modules/
package-lock.json
yarn.lock

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo
*~

# === Sistema Operativo ===
.DS_Store
Thumbs.db
desktop.ini

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Archivos temporales y respaldo ===
*.tmp
*.temp
*.bak
*.backup
