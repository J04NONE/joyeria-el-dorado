# ==========================================
#  Joyería El Dorado - Variables de Entorno
# ==========================================
# Copia este archivo como .env y ajusta los valores

# --- Django ---
SECRET_KEY=django-insecure-cambia_esto_en_produccion_123456
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de Datos ---
# Para desarrollo con SQLite (no requiere configuración extra):
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Para producción con PostgreSQL (descomentar y configurar):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=joyeria_db
# DB_USER=usuario_joyeria
# DB_PASSWORD=Base123
# DB_HOST=localhost
# DB_PORT=5432

# Para Neon (PostgreSQL serverless) - si se define, tiene prioridad sobre lo anterior:
# DATABASE_URL=postgresql://usuario:password@host.neon.tech/dbname?sslmode=require

# --- CORS ---
# En desarrollo, permitir todos los orígenes
CORS_ALLOW_ALL_ORIGINS=True
# En producción, listar orígenes específicos:
# CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com
